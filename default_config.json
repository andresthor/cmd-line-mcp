{
  "server": {
    "name": "cmd-line-mcp",
    "version": "0.5.1",
    "description": "MCP server for safely executing command-line tools",
    "log_level": "INFO"
  },
  "security": {
    "session_timeout": 3600,
    "max_output_size": 102400,
    "allow_user_confirmation": true,
    "require_session_id": false,
    "allow_command_separators": true,
    "whitelisted_directories": [
      "~/Downloads",
      "/tmp",
      "/usr/local/share"
    ],
    "auto_approve_directories_in_desktop_mode": false
  },
  "commands": {
    "read": [
      "ls", "pwd", "cat", "less", "head", "tail", "grep",
      "find", "which", "du", "df", "file", "uname", "hostname", 
      "uptime", "date", "whoami", "id", "env", "history", "man",
      "info", "help", "sort", "wc"
    ],
    "write": [
      "cp", "mv", "rm", "mkdir", "rmdir", "touch", "chmod", "chown",
      "ln", "echo", "printf", "export", "tar", "gzip", "zip", "unzip",
      "awk", "sed"
    ],
    "system": [
      "ps", "top", "htop", "who", "netstat", "ifconfig", "ping",
      "ssh", "scp", "curl", "wget", "xargs"
    ],
    "blocked": [
      "sudo", "su", "bash", "sh", "zsh", "ksh", "csh", "fish",
      "screen", "tmux", "nc", "telnet", "nmap",
      "dd", "mkfs", "mount", "umount", "shutdown", "reboot",
      "passwd", "chpasswd", "useradd", "userdel", "groupadd", "groupdel",
      "eval", "exec", "source", ".",
      "python", "python2", "python3",
      "perl", "ruby", "node", "nodejs",
      "lua", "php",
      "tclsh", "wish", "Rscript",
      "expect", "script"
    ],
    "dangerous_patterns": [
      "rm\\s+-rf\\s+/",
      ">\\s+/dev/(sd|hd|nvme|xvd)",
      ">\\s+/dev/null",
      ">\\s+/etc/",
      ">\\s+/boot/",
      ">\\s+/bin/",
      ">\\s+/sbin/",
      ">\\s+/usr/bin/",
      ">\\s+/usr/sbin/",
      ">\\s+/usr/local/bin/",
      "2>&1",
      "\\$\\(",
      "\\$\\{\\w+\\}",
      "`",
      "system\\s*\\(",
      "s/[^/]*/[^/]*/[a-zA-Z0-9]*e",
      "-exec\\s+(sh|bash|zsh|ksh|csh|fish|python[23]?|perl|ruby|node|env)\\b",
      "\\benv\\s+(sh|bash|zsh|ksh|csh|fish|python[23]?|perl|ruby|node)\\b",
      "\\bxargs\\s+(sh|bash|zsh|ksh|csh|fish|python[23]?|perl|ruby|node|env)\\b",
      "--to-command",
      "--checkpoint-action=exec"
    ]
  },
  "output": {
    "max_size": 102400,
    "format": "text"
  }
}
